# ── Microsoft / Graph ─────────────────────────────────────────────────────────
# Azure Entra tenant ID (the GUID, not the domain name).
MS_TENANT_ID=

# Azure App Registration client ID.
# This service uses the Device Code Flow (public client — no client secret needed).
MS_CLIENT_ID=

# Space-separated delegated MS Graph scopes.
# offline_access is required to receive a refresh token.
MS_GRAPH_SCOPES=https://graph.microsoft.com/ChannelMessage.Send https://graph.microsoft.com/offline_access

# Default connection_id used when no explicit connection_id is passed for MS calls.
MS_DEFAULT_CONNECTION_ID=ms-default


# ── Xero ──────────────────────────────────────────────────────────────────────
# Xero App client ID and secret (confidential client; secret is held server-side).
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Must match exactly what is registered in the Xero Developer Portal.
# Must be publicly reachable at setup time (i.e. when the OAuth flow is performed).
XERO_REDIRECT_URI=https://<your-host>/v1/oauth/xero/callback

# Space-separated Xero OAuth scopes.
XERO_SCOPES=openid profile email accounting.transactions accounting.contacts


# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL.  In Docker Compose the hostname is the service name "redis".
REDIS_URL=redis://redis:6379/0


# ── Application ───────────────────────────────────────────────────────────────
# Public base URL of this service (used when building Xero OAuth redirect URIs).
APP_BASE_URL=https://<your-host>

# How many seconds before token expiry to proactively refresh.
REFRESH_BUFFER_SECONDS=300

# How long (seconds) to keep the OAuth state key in Redis during Xero authorization dance.
OAUTH_STATE_TTL_SECONDS=600

# How long (seconds) to cache idempotency results in Redis.
IDEMPOTENCY_TTL_SECONDS=86400

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret used by OpenClaw to authenticate requests to this service.
# OpenClaw sends:  Authorization: Bearer <value>
# Keep this out of version control.  Use a secret manager in production.
INTERNAL_API_KEY=change-me-in-production
HOOK_TOKEN=change-me-in-production


# ── Seq (structured logging) ──────────────────────────────────────────────────
# Set SEQ_ENABLED=true to forward all log events to a Seq instance.
# When disabled, logs are written to stdout only.
SEQ_ENABLED=true
SEQ_URL=
SEQ_API_KEY=
SEQ_MIN_LEVEL=INFO
